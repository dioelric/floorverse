# ─── SERVER ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE (MySQL) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=floorverse

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── FILE UPLOADS ─────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# ─── AWS S3 (optional for Phase 2) ────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=floorverse-assets

# ─── EMAIL (optional for Phase 2) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@floorverse.io

# ─── RAZORPAY (optional for Phase 2) ──────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
